# =============================================
# Entorno virtual
# =============================================
venv/
env/
.venv/
 
# =============================================
# Python
# =============================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
 
# =============================================
# Variables de entorno (credenciales)
# =============================================
.env
.env.*
*.env
 
# =============================================
# Django
# =============================================
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static/
 
# =============================================
# Migraciones (se ignoran los cambios pero
# se conserva el __init__.py)
# =============================================
*/migrations/*.py
!*/migrations/__init__.py
 
# =============================================
# IDEs y editores
# =============================================
.vscode/
.idea/
*.swp
*.swo
 
# =============================================
# Sistema operativo
# =============================================
.DS_Store
Thumbs.db
desktop.ini